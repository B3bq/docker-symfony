{% extends "base.html.twig" %}

{% block title %}Podgląd Ankiety{% endblock %}

{% block navigation %}
    <li><a href="{{ path('homepage') }}">Strona główna</a></li>
    <li><a href="{{ path('survey_list') }}">Moje ankiety</a></li>
    {% if is_granted('ROLE_ADMIN') %}
        <li><a href="{{ path('admin_panel') }}">Panel administratora</a></li>
    {% endif %}
{% endblock %}


{% block content %}
<div class="container mt-5 no-edit">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="mb-4">Podgląd Ankiety</h2>
            
            {{ form_start(form) }}
            
            <div class="card mb-4 shadow-sm border-0 bg-light">
                <div class="card-body">
                    <div class="mb-3">
                        {{ form_row(form.title, {'label_attr': {'class': 'fw-bold'}}) }}
                    </div>
                    <div class="mb-3">
                        {{ form_row(form.description, {'label_attr': {'class': 'fw-bold'}}) }}
                    </div>
                </div>
            </div>

            <h4 class="mb-3">Pytania</h4>
            <div class="questions-wrapper" 
                 data-prototype="{{ form_widget(form.questions.vars.prototype)|e('html_attr') }}"
                 data-index="{{ form.questions|length }}">
                
                {% for questionForm in form.questions %}
                    <div class="card mb-4 border-primary question-item">
                        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                            <strong>Pytanie</strong>
                        </div>
                        <div class="card-body">
                            {{ form_row(questionForm.content) }}
                            
                            <h6 class="text-muted mb-3">Warianty odpowiedzi:</h6>
                               <div class="answers-wrapper"
                                   data-prototype="{{ form_widget(questionForm.answers.vars.prototype)|e('html_attr') }}"
                                   data-index="{{ questionForm.answers|length }}"
                                   data-question-index="{{ loop.index0 }}">
                                
                                {% for answerForm in questionForm.answers %}
                                    <div class="input-group mb-2 answer-item">
                                        <div class="input-group-text bg-light">
                                            <input type="radio" class="correct-answer-radio" {% if answerForm.isCorrect.vars.data %}checked{% endif %}>
                                            {{ form_widget(answerForm.isCorrect, {'attr': {'style': 'display: none;'}}) }}
                                        </div>
                                        {{ form_widget(answerForm.content, {'attr': {'class': 'form-control', 'placeholder': 'Treść odpowiedzi'}}) }}
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        
            <div class="d-none">
                {{ form_rest(form) }}
            </div>
            
            {{ form_end(form) }}

        </div>
    </div>
</div>
{% endblock %}