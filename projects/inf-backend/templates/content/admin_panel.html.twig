{% extends 'base.html.twig' %}

{% block title %}Admin Panel{% endblock %}

{% block navigation %}
    {% if app.user and is_granted('ROLE_ADMIN') %}
        <li><a href="{{ path('homepage') }}">Strona główna</a></li>
        <li><a href="{{ path('survey_list') }}">Moje ankiety</a></li>
        <li><a href="{{ path('admin_panel') }}">Panel administratora</a></li>
        <li><a href="{{ path('app_logout') }}">Wyloguj się ({{ app.user.email }})</a></li>
    {% endif %}
{% endblock %}

{% block content %}
    {% block javascripts %}
        {{ importmap('survey_list') }}
    {% endblock %}
    <div>
        <h2>Panel administratora</h2>
        <p>Witaj w panelu administratora! Tutaj możesz zarządzać użytkownikami i ankietami.</p>

        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h3 class="card-title h5">Zarządzanie użytkownikami</h3>
                        <p class="card-text text-muted">Przeglądaj, edytuj i usuwaj użytkowników z systemu.</p>
                    </div>
                </div>
                <div>
                    <h4>Lista użytkowników:</h4>
                    {% if users is empty %}
                        <p class="text-muted">Brak dostępnych użytkowników.</p>
                    {% else %}
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Email</th>
                                    <th>Rola</th>
                                    <th>Akcje</th>
                                </tr>
                            </thead>
                                    <tbody>
                                        {% for user in users %}
                                            <tr class="trs" data-user-id="{{ user.id }}" data-update-url="{{ path('admin_update_user_roles', {'id': user.id}) }}">
                                                <td>{{ loop.index }}</td>
                                                <td>{{ user.email }}</td>
                                                <td class="user-roles" data-user-id="{{ user.id }}">
                                                    <div class="roles-list">
                                                                        {% for role in user.roles %}
                                                                            <span class="badge bg-secondary me-1 role-badge" data-role="{{ role }}">{{ role }}
                                                                                {% if role != 'ROLE_USER' %}
                                                                                    <button type="button" class="btn-close remove-role ms-2" aria-label="Usuń" style="display:none;" data-role="{{ role }}">X</button>
                                                                                {% endif %}
                                                                            </span>
                                                                        {% endfor %}
                                                    </div>
                                                </td>
                                                <td>
                                                    <button class="btn btn-sm btn-outline-primary edit-roles" data-user-id="{{ user.id }}">Edytuj role</button>
                                                    <a href="{{ path('admin_delete_user', {'id': user.id}) }}" class="btn btn-sm btn-danger" onclick="return confirm('Czy na pewno chcesz usunąć tego użytkownika?');">
                                                        Usuń konto
                                                    </a>
                                                    <div class="role-editor mt-2" style="display:none;">
                                                        <div class="input-group input-group-sm">
                                                            <select class="form-select role-select">
                                                                <option value="">Wybierz rolę...</option>
                                                                {% for r in available_roles %}
                                                                    <option value="{{ r }}">{{ r }}</option>
                                                                {% endfor %}
                                                            </select>
                                                            <button class="btn btn-sm btn-success add-role" type="button">Dodaj rolę</button>
                                                            <button class="btn btn-sm btn-primary confirm-roles ms-2" type="button">Zatwierdź</button>
                                                            <button class="btn btn-sm btn-secondary cancel-edit ms-2" type="button">Anuluj</button>
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                        </table>
                    {% endif %}
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h3 class="card-title h5">Zarządzanie ankietami</h3>
                        <p class="card-text text-muted">Przeglądaj, edytuj i usuwaj ankiety utworzone przez użytkowników.</p>
                        <div id="user-surveys-list" class="mt-3">
                            <p class="text-muted">Kliknij użytkownika, aby zobaczyć jego ankiety.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}