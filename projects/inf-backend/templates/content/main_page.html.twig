{% extends 'base.html.twig' %}


{% block navigation %}
    {% if app.user %}
        <li><a href="{{ path('homepage') }}">Strona główna</a></li>
        <li><a href="{{ path('survey_list') }}">Moje ankiety</a></li>
        <li><a href="{{ path('app_logout') }}">Wyloguj się ({{ app.user.email }})</a></li>
    {% else %}
        <li><a href="{{ path('homepage') }}">Strona główna</a></li>
        <li><a href="{{ path('signin') }}">Zaloguj się</a></li>
        <li><a href="{{ path('signup') }}">Zarejestruj się</a></li>
    {% endif %}
{% endblock %}

{% block content %}
    <div>
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Witaj na stronie głównej ankiet!</h2>
            {% if app.user %}
                <a href="{{ path('survey_create') }}" class="btn btn-success">+ Stwórz nowy quiz</a>
            {% endif %}
        </div>

        <div class="row">
            <ol>
            {% for survey in content %}
                <li>
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h3 class="card-title h5">{{ survey.title }}</h3>
                            <p class="card-text text-muted">{{ survey.description }}</p>
                        </div>
                        <div class="card-footer bg-white border-top-0">
                            <a href="{{ path('survey_answer', {'id': survey.id}) }}" class="btn btn-primary w-100">Rozwiąż quiz</a>
                        </div>
                        {% if app.user and survey.user_id == app.user.id %}
                            <div class="card-footer bg-white border-top-0">
                                <a href="{{ path('survey_edit', {'id': survey.id}) }}" class="btn btn-secondary w-100">Edytuj quiz</a>
                            </div>
                        {% endif %}
                    </div>
                </div>
                </li>
            {% else %}
                <div class="col-12">
                    <p class="text-muted">Brak dostępnych quizów. Stwórz pierwszy!</p>
                </div>
            {% endfor %}
            </ol>
        </div>
    </div>
{% endblock %}